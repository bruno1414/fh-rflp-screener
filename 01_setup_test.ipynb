   "source": [
    "from Bio.Restriction import MspI\n",
    "from Bio.Seq import Seq\n",
    "\n",
    "test_seq = Seq(\"AATGCCGGTTAAGCCGGAATC\")\n",
    "cuts = MspI.catalyze(test_seq, linear=True)\n",
    "print(f\"Cut positions: {cuts}\")\n",
    "print(f\"Number of cuts: {len(cuts)}\")\n",
    "print(\"Phase 1 complete!\")\n"
   ]
  },
